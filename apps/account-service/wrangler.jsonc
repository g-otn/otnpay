{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "otnpay-account-service",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-19",
  "compatibility_flags": ["nodejs_compat"],
  "dev": {
    "port": 9510
  },
  "vars": {},
  "env": {
    "dev_docker": {
      "vars": {},
      "workers_dev": false,
      "version_metadata": {
        "binding": "CF_VERSION_METADATA"
      }
    }
  },
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  }
}
